{
   "manifest_version": 3,
   "name": "Sparkle News",
   "description": "Get the latest news and updates in your browser with Sparkle News.",
   "short_name": "SN",
   "version": "1.0.0",
   "icons": {
      "16": "images/sm.png",
      "32": "images/sm.png",
      "48": "images/sm.png",
      "128": "images/sm.png"
   },
   "background": {
      "service_worker": "js/background.js"
   },
   "action": {
      "default_icon": {
         "16": "images/sm.png",
         "32": "images/sm.png"
      },
      "default_popup": "html/starter.html",
      "default_title": "Sparkle News"
   },
   "permissions": [
      "storage",
      "alarms"
   ],
   "host_permissions": [
      "https://economictimes.indiatimes.com/*",
      "https://json.bselivefeeds.indiatimes.com/*",
      "https://pflivefeeds.indiatimes.com/*"
   ],
   "web_accessible_resources": [
      {
         "resources": [
            "images/*",
            "img/*"
         ],
         "matches": [
            "<all_urls>"
         ]
      }
   ]
}